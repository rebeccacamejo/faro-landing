# Get your key at https://resend.com/api-keys
RESEND_API_KEY=your_key_here

# Sender address — must be a verified domain in production.
# For local testing use the Resend sandbox default.
RESEND_FROM_EMAIL=Faro <onboarding@resend.dev>

# Where notification emails go
NOTIFY_EMAIL=rcamejo04@gmail.com

# Supabase — get these from Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Public base URL for building referral links
NEXT_PUBLIC_BASE_URL=https://faro-jet.vercel.app

# Admin page protection — any hard-to-guess string
ADMIN_SECRET=change_me
